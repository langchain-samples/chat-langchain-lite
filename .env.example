# Copy this file to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=lsv2_sk_...
ANTHROPIC_BASE_URL="https://gateway.smith.langchain.com/anthropic"
ANTHROPIC_CUSTOM_HEADERS="X-Api-Key: lsv2_sk_..."

# LangSmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=chat-langchain-lite
LANGSMITH_WORKSPACE_ID=your-demo-workspace-id
LANGSMITH_API_KEY_GATEWAY=your-demo-gateway-key

DEMO_PRESENTER="robert"

# FastHTML frontend (optional)
# Base URL the frontend uses to reach the co-located graph over the LangGraph
# SDK. Must be loopback. Defaults to the `langgraph dev` port; set to
# http://localhost:8000 in a deployment (the container's API port).
# LANGGRAPH_API_URL=http://localhost:2024

# Secret used to sign the session cookie that holds the chat thread id.
# Set this in any real deployment so sessions survive a restart.
# SESSION_SECRET=change-me-in-production
